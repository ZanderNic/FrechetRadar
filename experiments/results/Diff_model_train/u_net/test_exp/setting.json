
{
  "device": "cpu",
  "num_workers": 1,
  "batch_size": 2,
  "num_trys": 1,

  "discretizer_params": {
    "grid_size": 32,
    "x_min": -1,
    "x_max": 1,
    "y_min": -1,
    "y_max": 1,
    "valid_indicator": 1.0
  },

  "data_generator": [
    {
      "lambda_lines_2d": 10,
      "lambda_points_line_2d": 20,
      "lambda_clutter": 50
    }
  ],

  "dataset": {
    "type": "streaming"
  },
  
  "diffusion_model": {
      "u_net" : {
        "channels_per_level" : [4, 8, 8, 8],
        "attention_levels" : [0, 0, 0, 1],
        "resnet_blocks_per_depth" : 1
      },

      "loss" : {
          "loss_type" : "weighted_mse",
          "args" : {
              "channel_weights" : [1,1,1,1]
          }
      },

      "sampling_args": {
          "sample_time_steps": 10,
          "sampler": "ddim",
          "use_ema_model": true,
          "eta" : 0.0
      },

      "prediction_type": "x0",

      "time_steps" : 1000,
      "schedule_type": "cosine",
      "learing_rate": 5e-5,
      "max_grad_norm" : 1.0,
      "betas": [0.9, 0.999],
      "weight_decay": 0,
      "use_scheduler": false,

      "sinus_time_embeding_dim" : 256,
      "mlp_time_embeding_dim" : 256,
      
      "log_train_loss_per_batch" : 5
    },


  "random_projection_dims": [128],

  "training_evaluation_batches" : [10, 20, 30],
  "save_samples" : true,
  "checkpoint_models" : true,

  "sample_sizes": [256, 512]
}
