{
  "device": "auto",
  "num_workers": 8,
  "batch_size": 32,
  "num_trys": 1,

  "discretizer_params": {
    "grid_size": 64,
    "x_min": -1,
    "x_max": 1,
    "y_min": -1,
    "y_max": 1,
    "valid_indicator": 1.0
  },

  "data_generator": [
    {
      "lambda_lines_2d": 10,
      "lambda_points_line_2d": 20,
      "lambda_clutter": 50
    }
  ],

  "dataset": {
    "type": "streaming"
  },

  "diffusion_model": {
    "u_net" : {
      "channels_per_level" : [16, 32, 64, 128],
      "attention_levels" : [0, 0, 1, 1],
      "resnet_blocks_per_depth" : 2
    },

    "loss" : {
        "loss_type" : "weighted_mse",
        "args" : {
            "channel_weights" : [1,1,1,1]
        }
    },

    "sampling_args": {
        "sample_time_steps": 20,
        "sampler": "ddim",
        "use_ema_model": true,
        "eta" : 0.0
    },

    "prediction_type": "x0",

    "time_steps" : 1000,
    "schedule_type": "cosine",
    "learing_rate": 1e-4,
    "max_grad_norm" : 1.0,
    "betas": [0.9, 0.999],
    "weight_decay": 0,
    "use_scheduler": false,

    "sinus_time_embeding_dim" : 256,
    "mlp_time_embeding_dim" : 512,
    
    "log_train_loss_per_batch" : 1000
  },

  "random_projection_dims": [128, 256, 512],

  "training_evaluation_batches" : [0, 10000, 20000, 30000, 40000, 60000, 80000, 120000, 160000, 200000, 240000, 280000, 320000, 400000, 450000, 500000, 600000, 700000, 800000, 900000],
  "save_samples" : true,
  "checkpoint_models" : true,

  "sample_sizes": [256, 512, 1024, 2048, 4096, 8192, 16384, 32768]
}
