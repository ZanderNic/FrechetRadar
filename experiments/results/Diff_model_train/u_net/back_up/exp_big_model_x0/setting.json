
{
  "device": "auto",
  "num_workers": 8,
  "batch_size": 32,
  "num_trys": 1,

  "discretizer_params": {
    "grid_size": 64,
    "x_min": -1,
    "x_max": 1,
    "y_min": -1,
    "y_max": 1,
    "valid_indicator": 1.0
  },

  "data_generator": [
    {
      "lambda_lines_2d": 10,
      "lambda_points_line_2d": 20,
      "lambda_clutter": 50
    }
  ],

  "dataset": {
    "type": "streaming"
  },

  "diffusion_model": {
    "u_net" : {
      "channels_per_level" : [64, 128, 256, 512],
      "attention_levels" : [0, 0, 1, 1],
      "resnet_blocks_per_depth" : 2
    },

    "loss" : {
        "loss_type" : "weighted_mse",
        "args" : {
            "channel_weights" : [1,1,1,1]
        }
    },

    "prediction_type": "x0",
    "time_steps" : 1000,
    "sinus_time_embeding_dim" : 256,
    "mlp_time_embeding_dim" : 512,
    "schedule_type": "cosine",
    "log_train_loss_per_batch" : 100
  },

  "random_projection_dims": [128],

  "training_evaluation_batches" : [20000, 40000, 60000, 80000, 100000, 110000, 120000, 130000, 140000, 150000, 160000, 170000, 180000, 190000, 200000, 210000, 220000, 230000, 240000, 250000, 300000, 400000, 450000, 500000],
  "save_samples" : true,
  "checkpoint_models" : true,

  "sample_sizes": [256, 512, 1024, 2048, 4096, 8192]
}
